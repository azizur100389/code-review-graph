{
  "_comment": "PostEdit and PostGit are custom Claude Code hook events (confirmed working as of v1.6.4).",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PostEdit": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "code-review-graph update 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostGit": [
      {
        "matcher": "commit",
        "hooks": [
          {
            "type": "command",
            "command": "code-review-graph update 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
